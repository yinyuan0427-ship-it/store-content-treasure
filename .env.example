# ═══════════════════════════════════════════════
# TEMPUR 门店内容宝 · 环境变量
# ═══════════════════════════════════════════════
# 部署时复制此文件为 .env：
#   cp .env.example .env
# 并修改下面的密钥和密码为真实值。
#
# .env 已在 .gitignore 中，不会上传到 GitHub。

# ── 服务器 ──
PORT=3001
NODE_ENV=production

# ── JWT 密钥（务必修改为随机字符串）──
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-secret

# ── 存储模式 ──
# LOCAL_STORE=1  → 免数据库，JSON 文件存储（推荐首次上线使用）
# LOCAL_STORE=0  → 使用 PostgreSQL（需要配置下面的 PG* 变量）
LOCAL_STORE=1

# ── 上传目录 ──
UPLOAD_DIR=./uploads

# ── PostgreSQL（仅 LOCAL_STORE=0 时需要）──
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=store_content_treasure
# PGUSER=postgres
# PGPASSWORD=postgres
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/store_content_treasure

# ── 前端公开域名（生成分享链接时使用）──
# VITE_PUBLIC_SHARE_BASE_URL=https://your-domain.com

# ── Supabase（未来可选）──
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
